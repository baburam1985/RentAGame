FROM node:20-bookworm-slim
WORKDIR /app

# Install Chromium and required system libraries for Playwright headless mode
RUN apt-get update && apt-get install -y --no-install-recommends \
    chromium \
    fonts-liberation \
    libasound2 \
    libatk-bridge2.0-0 \
    libatk1.0-0 \
    libcups2 \
    libdbus-1-3 \
    libdrm2 \
    libgbm1 \
    libnspr4 \
    libnss3 \
    libxcomposite1 \
    libxdamage1 \
    libxfixes3 \
    libxkbcommon0 \
    libxrandr2 \
    && rm -rf /var/lib/apt/lists/*

# Use system-installed Chromium; skip Playwright's own browser download
ENV PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=1
ENV CHROMIUM_PATH=/usr/bin/chromium

# Use npm install (not npm ci) so npm selects glibc binaries for this platform.
# The package-lock.json was generated on Alpine/musl — npm ci installs the wrong
# native binaries (musl Rolldown/Oxide) which crash on Debian glibc at runtime.
COPY package.json ./
RUN npm install --no-audit --no-fund

COPY . .

CMD ["npm", "run", "test:e2e"]
