FROM node:20-alpine
WORKDIR /app

# Install Chromium and its runtime dependencies (all available in Alpine repos).
# Note: xvfb and udev are NOT in Alpine repos and NOT needed — headless Chromium
# runs without a display server.
RUN apk add --no-cache \
    chromium \
    nss \
    freetype \
    harfbuzz \
    ca-certificates \
    ttf-freefont

# Tell Playwright to use the system-installed Chromium instead of downloading
ENV PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=1
ENV CHROMIUM_PATH=/usr/bin/chromium-browser

# Install all deps (including dev)
COPY package.json package-lock.json ./
RUN npm ci

# Copy source
COPY . .

CMD ["npm", "run", "test:run"]
